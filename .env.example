# Neon Database Connection (PostgreSQL)
# Get this from: https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxxxx.us-east-1.neon.tech/neondb
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxxxx.us-east-1.neon.tech/neondb?sslmode=require

# Admin Panel Password (change this to a strong password)
ADMIN_PASSWORD=admin

# JWT Secret for authentication (change this to a random string)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Node environment
NODE_ENV=development
